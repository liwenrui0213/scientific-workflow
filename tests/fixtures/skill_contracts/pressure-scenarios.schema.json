{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scientific workflow Skill pressure-scenario catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenarios"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "scenarios": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "skill",
          "pressure_sources",
          "prompt",
          "expected_actions",
          "forbidden_actions",
          "invariant_under_test"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+-[0-9]{2}$"
          },
          "skill": {
            "enum": [
              null,
              "bootstrap-scientific-workflow",
              "start-scientific-study",
              "scientific-study",
              "research-compaction",
              "scientific-review"
            ]
          },
          "pressure_sources": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "prompt": {
            "type": "string",
            "minLength": 20
          },
          "expected_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "invariant_under_test": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    }
  }
}
