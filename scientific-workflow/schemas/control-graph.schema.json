{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/control-graph.schema.json",
  "title": "Versioned Control Graph specification",
  "type": "object",
  "x-maxCanonicalBytes": 262144,
  "required": [
    "schema_version",
    "record_type",
    "study_id",
    "control_graph_id",
    "version",
    "status",
    "created_at",
    "updated_at",
    "previous_ref",
    "realizes_intent",
    "executor",
    "resources",
    "nodes",
    "edges",
    "completion",
    "record_sha256"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "record_type": {"const": "control_graph_spec"},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$"},
    "control_graph_id": {"type": "string", "pattern": "^CG-[0-9]{4,}$"},
    "version": {"type": "integer", "minimum": 1},
    "status": {"enum": ["draft", "finalized"]},
    "created_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "updated_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "previous_ref": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["control_graph_id", "version", "sha256"],
          "properties": {
            "control_graph_id": {"type": "string", "pattern": "^CG-[0-9]{4,}$"},
            "version": {"type": "integer", "minimum": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          },
          "additionalProperties": false
        }
      ]
    },
    "realizes_intent": {
      "type": "object",
      "required": ["intent_id", "version", "sha256"],
      "properties": {
        "intent_id": {"type": "string", "pattern": "^INTENT-[0-9]{4,}$"},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "executor": {
      "type": "object",
      "required": ["kind", "parameters"],
      "properties": {
        "kind": {"type": "string", "minLength": 1, "maxLength": 128},
        "parameters": {"type": "object"}
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "required": ["cpu_hours", "gpu_hours", "storage_gb", "parallel_workers"],
      "properties": {
        "cpu_hours": {"type": "number", "minimum": 0},
        "gpu_hours": {"type": "number", "minimum": 0},
        "storage_gb": {"type": "number", "minimum": 0},
        "parallel_workers": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["node_id", "kind", "purpose"],
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]{0,127}$"
          },
          "kind": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "purpose": {"type": "string", "minLength": 1, "maxLength": 4096},
          "command": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "array",
                "minItems": 1,
                "maxItems": 256,
                "items": {"type": "string", "minLength": 1, "maxLength": 8192}
              }
            ]
          },
          "loop_contract": {
            "oneOf": [
              {"type": "null"},
              {"type": "object"}
            ]
          },
          "specification": {"type": "object"},
          "metadata": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "maxItems": 2048,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["from", "to", "condition"],
        "properties": {
          "from": {"type": "string", "minLength": 1},
          "to": {"type": "string", "minLength": 1},
          "condition": {
            "oneOf": [
              {"type": "null"},
              {"type": "string", "minLength": 1, "maxLength": 4096},
              {"type": "object"}
            ]
          },
          "relation": {"type": "string", "minLength": 1, "maxLength": 128},
          "metadata": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "completion": {
      "type": "object",
      "required": ["required_node_ids", "on_incomplete"],
      "properties": {
        "required_node_ids": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "on_incomplete": {"type": "string", "minLength": 1, "maxLength": 256},
        "criteria": {
          "type": "array",
          "maxItems": 256,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "specification": {"type": "object"}
      },
      "additionalProperties": false
    },
    "record_sha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
