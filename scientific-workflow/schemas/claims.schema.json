{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/claims.schema.json",
  "title": "Current scientific Claims state",
  "type": "object",
  "required": ["schema_version", "study_id", "revision", "updated_at", "claims", "frontier"],
  "properties": {
    "schema_version": {"const": 3},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$", "maxLength": 64},
    "revision": {"type": "integer", "minimum": 1},
    "updated_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "claims": {"type": "array", "maxItems": 256, "items": {"$ref": "#/$defs/claim"}},
    "frontier": {"$ref": "#/$defs/frontier"}
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "version", "sha256"],
      "properties": {
        "evidence_id": {"type": "string", "pattern": "^EVID-[0-9]{4,}$", "maxLength": 64},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
      "required": [
        "claim_id", "statement", "scope", "state", "evidence_basis", "lifecycle", "supporting_evidence",
        "contradictory_evidence", "other_evidence", "uncertainty", "limitations", "updated_at"
      ],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^CLAIM-[0-9]{4,}$", "maxLength": 64},
        "statement": {"type": "string", "minLength": 1, "maxLength": 4096},
        "scope": {"type": ["string", "null"], "maxLength": 4096},
        "state": {"enum": ["proposed", "under_test", "partially_supported", "numerically_supported", "contradicted", "inconclusive"]},
        "evidence_basis": {"enum": ["none", "exploratory", "confirmatory", "mixed"]},
        "lifecycle": {"enum": ["active", "retired", "superseded"]},
        "superseded_by": {"type": ["string", "null"], "pattern": "^CLAIM-[0-9]{4,}$", "maxLength": 64},
        "supporting_evidence": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"$ref": "#/$defs/evidence_ref"}},
        "contradictory_evidence": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"$ref": "#/$defs/evidence_ref"}},
        "other_evidence": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"$ref": "#/$defs/evidence_ref"}},
        "conflict_disposition": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/conflict_disposition"}
          ]
        },
        "uncertainty": {"type": ["string", "null"], "maxLength": 4096},
        "limitations": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 1024}},
        "updated_at": {"type": "string", "minLength": 1, "maxLength": 64}
      },
      "additionalProperties": false
    },
    "conflict_disposition": {
      "type": "object",
      "required": ["status", "synthesis"],
      "properties": {
        "status": {"enum": ["resolved", "scope_limited", "unresolved"]},
        "synthesis": {"type": "string", "minLength": 1, "maxLength": 4096}
      },
      "additionalProperties": false
    },
    "frontier": {
      "type": "object",
      "required": ["summary", "claim_ids", "open_questions", "human_decisions_required"],
      "properties": {
        "summary": {"type": ["string", "null"], "maxLength": 4096},
        "claim_ids": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "pattern": "^CLAIM-[0-9]{4,}$", "maxLength": 64}},
        "open_questions": {"type": "array", "maxItems": 64, "items": {"type": "string", "maxLength": 1024}},
        "human_decisions_required": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 1024}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
