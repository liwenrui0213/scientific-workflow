{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/verdict.schema.json",
  "title": "Human implementation and scientific Verdict",
  "type": "object",
  "required": [
    "schema_version", "study_id", "verdict_id", "created_at", "reviewer",
    "judged_scope", "implementation_verdict", "scientific_verdict", "confirmation",
    "verdict_sha256"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$"},
    "verdict_id": {"type": "string", "pattern": "^VERDICT-[0-9]{4,}$"},
    "created_at": {"type": "string", "minLength": 1},
    "reviewer": {
      "type": "object",
      "required": ["identity", "source"],
      "properties": {
        "identity": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "authorization": {
      "type": "object",
      "required": [
        "mode", "source", "assurance", "instruction", "instruction_sha256"
      ],
      "properties": {
        "mode": {"const": "agent_initiated"},
        "source": {"const": "explicit_user_instruction"},
        "assurance": {"const": "cooperative"},
        "instruction": {"type": "string", "minLength": 1},
        "instruction_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "judged_scope": {
      "type": "object",
      "required": ["commit", "brief_sha256", "checkpoint", "claims", "evidence"],
      "properties": {
        "commit": {"type": ["string", "null"]},
        "brief_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "checkpoint": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/checkpoint_ref"}
          ]
        },
        "claims": {"type": "array", "items": {"$ref": "#/$defs/claim_ref"}},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence_ref"}}
      },
      "additionalProperties": false
    },
    "implementation_verdict": {
      "type": "object",
      "required": ["decision", "rationale", "conditions"],
      "properties": {
        "decision": {"enum": ["accepted", "rejected", "requires_changes"]},
        "rationale": {"type": "string", "minLength": 1},
        "conditions": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "scientific_verdict": {
      "type": "object",
      "required": ["decision", "rationale", "scope", "conditions"],
      "properties": {
        "decision": {"enum": ["accepted_within_scope", "rejected", "requires_more_evidence"]},
        "rationale": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "conditions": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "confirmation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["typed_text", "confirmed_at"],
          "properties": {
            "typed_text": {"type": "string", "minLength": 1},
            "confirmed_at": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["mode", "recorded_at"],
          "properties": {
            "mode": {"const": "agent_initiated"},
            "recorded_at": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        }
      ]
    },
    "verdict_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "checkpoint_ref": {
      "type": "object",
      "required": ["checkpoint_id", "sha256"],
      "properties": {
        "checkpoint_id": {"type": "string", "pattern": "^CHECKPOINT-[0-9]{6}$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "claim_ref": {
      "type": "object",
      "required": ["claim_id", "sha256"],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^CLAIM-[0-9]{4,}$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "version", "sha256"],
      "properties": {
        "evidence_id": {"type": "string", "pattern": "^EVID-[0-9]{4,}$"},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
