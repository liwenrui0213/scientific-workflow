{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/observation.schema.json",
  "title": "Optional versioned Observation Record",
  "type": "object",
  "x-maxCanonicalBytes": 131072,
  "x-maxCanonicalBytesStatuses": ["draft"],
  "required": [
    "schema_version", "study_id", "observation_id", "version", "status",
    "created_at", "updated_at", "promotion", "runs", "cohorts", "analysis",
    "results", "uncertainty", "scope", "anomalies",
    "representative_failures", "analysis_assumptions", "limitations",
    "analysis_fingerprint_sha256", "record_sha256"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "study_id": {
      "type": "string",
      "pattern": "^SC-[0-9]{4,}$",
      "maxLength": 64
    },
    "observation_id": {
      "type": "string",
      "pattern": "^OBS-[0-9]{4,}$",
      "maxLength": 64
    },
    "version": {"type": "integer", "minimum": 1},
    "status": {"enum": ["draft", "finalized"]},
    "created_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "updated_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "promotion": {
      "type": "object",
      "required": ["registry", "triggers", "rationale"],
      "properties": {
        "registry": {
          "type": "object",
          "required": ["version", "sha256"],
          "properties": {
            "version": {"type": "integer", "minimum": 1},
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          "additionalProperties": false
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,63}$"
          }
        },
        "rationale": {"type": ["string", "null"], "maxLength": 4096}
      },
      "additionalProperties": false
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {"$ref": "#/$defs/run_ref"}
    },
    "cohorts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/cohort_ref"}
    },
    "analysis": {
      "type": "object",
      "required": [
        "method", "implementation_sha256", "evaluator_sha256",
        "inclusion_rule", "exclusion_rule", "aggregation_rule",
        "changed_cohort_fields", "cohort_compatibility_justification"
      ],
      "properties": {
        "method": {"type": ["string", "null"], "maxLength": 8192},
        "implementation_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "evaluator_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "inclusion_rule": {"type": ["string", "null"], "maxLength": 4096},
        "exclusion_rule": {"type": ["string", "null"], "maxLength": 4096},
        "aggregation_rule": {"type": ["string", "null"], "maxLength": 4096},
        "changed_cohort_fields": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        },
        "cohort_compatibility_justification": {
          "type": ["string", "null"],
          "maxLength": 8192
        }
      },
      "additionalProperties": false
    },
    "results": {
      "type": "object",
      "required": ["primary", "secondary", "distribution", "boundary_cases"],
      "properties": {
        "primary": {
          "type": ["object", "string", "number", "array", "boolean", "null"]
        },
        "secondary": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": ["object", "string", "number", "array", "boolean", "null"]
          }
        },
        "distribution": {
          "type": ["object", "array", "string", "number", "null"]
        },
        "boundary_cases": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": ["object", "string", "number", "array", "boolean", "null"]
          }
        }
      },
      "additionalProperties": false
    },
    "uncertainty": {
      "type": "object",
      "required": ["statistical", "numerical", "measurement"],
      "properties": {
        "statistical": {"$ref": "#/$defs/nullable_result"},
        "numerical": {"$ref": "#/$defs/nullable_result"},
        "measurement": {"$ref": "#/$defs/nullable_result"}
      },
      "additionalProperties": false
    },
    "scope": {"type": ["string", "null"], "maxLength": 4096},
    "anomalies": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/anomaly"}
    },
    "representative_failures": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^RUN-[0-9]{6}$"
      }
    },
    "analysis_assumptions": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 2048}
    },
    "limitations": {
      "type": "array",
      "maxItems": 64,
      "items": {"type": "string", "minLength": 1, "maxLength": 2048}
    },
    "analysis_fingerprint_sha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "record_sha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "nullable_result": {
      "type": ["object", "string", "number", "array", "boolean", "null"]
    },
    "run_ref": {
      "type": "object",
      "required": [
        "run_id", "manifest_sha256", "disposition", "rationale"
      ],
      "properties": {
        "run_id": {"type": "string", "pattern": "^RUN-[0-9]{6}$"},
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "disposition": {
          "enum": ["included", "excluded", "anomaly", "representative_failure"]
        },
        "rationale": {"type": ["string", "null"], "maxLength": 2048}
      },
      "additionalProperties": false
    },
    "cohort_ref": {
      "type": "object",
      "required": ["cohort_id", "fingerprint_sha256"],
      "properties": {
        "cohort_id": {
          "type": ["string", "null"],
          "pattern": "^COHORT-[0-9]{3,}$"
        },
        "fingerprint_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "anomaly": {
      "type": "object",
      "required": ["run_id", "observation"],
      "properties": {
        "run_id": {"type": "string", "pattern": "^RUN-[0-9]{6}$"},
        "observation": {"type": "string", "minLength": 1, "maxLength": 4096}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
