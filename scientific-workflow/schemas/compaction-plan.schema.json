{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/compaction-plan.schema.json",
  "title": "Research compaction plan",
  "type": "object",
  "required": [
    "schema_version", "study_id", "compaction_input_sha256", "claims_sha256",
    "evidence_inventory", "archive_work_files", "decisive_evidence",
    "contradictory_evidence", "frontier",
    "representative_failures", "budget_state"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$", "maxLength": 64},
    "compaction_input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claims_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_inventory": {"$ref": "#/$defs/inventory_binding"},
    "occurrence_inventory": {"$ref": "#/$defs/inventory_binding"},
    "archive_work_files": {"type": "array", "maxItems": 256, "items": {"type": "string", "minLength": 1, "maxLength": 1024}},
    "decisive_evidence": {"type": "array", "maxItems": 2048, "items": {"$ref": "#/$defs/evidence_ref"}},
    "contradictory_evidence": {"type": "array", "maxItems": 2048, "items": {"$ref": "#/$defs/evidence_ref"}},
    "frontier": {"type": "object"},
    "representative_failures": {"type": "array", "maxItems": 64, "items": {"type": "string", "maxLength": 1024}},
    "budget_state": {"type": "object"}
  },
  "$defs": {
    "inventory_binding": {
      "type": "object",
      "required": ["total_count", "inventory_sha256"],
      "properties": {
        "total_count": {"type": "integer", "minimum": 0},
        "inventory_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "version", "sha256"],
      "properties": {
        "evidence_id": {"type": "string", "pattern": "^EVID-[0-9]{4,}$", "maxLength": 64},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
