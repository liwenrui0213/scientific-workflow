{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/compaction-plan.schema.json",
  "title": "Research compaction plan",
  "type": "object",
  "required": [
    "schema_version", "study_id", "compaction_input_sha256", "claims_sha256",
    "evidence_sha256", "archive_work_files", "decisive_evidence",
    "contradictory_evidence", "frontier", "open_questions", "next_actions",
    "representative_failures", "budget_state"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$"},
    "compaction_input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claims_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_sha256": {"type": "object"},
    "archive_work_files": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "decisive_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence_ref"}},
    "contradictory_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence_ref"}},
    "frontier": {"type": "object"},
    "open_questions": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "representative_failures": {"type": "array", "items": {"type": "string"}},
    "budget_state": {"type": "object"}
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "version", "sha256"],
      "properties": {
        "evidence_id": {"type": "string", "pattern": "^EVID-[0-9]{4,}$"},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
