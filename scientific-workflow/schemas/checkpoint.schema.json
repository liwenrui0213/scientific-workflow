{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/checkpoint.schema.json",
  "title": "Immutable research compaction Checkpoint",
  "type": "object",
  "required": [
    "schema_version", "study_id", "checkpoint_id", "created_at", "brief",
    "active_formal_artifacts", "claims_file_sha256", "claims_snapshot",
    "inactive_claim_refs", "active_context_watermarks", "frontier",
    "decisive_evidence", "contradictory_evidence", "decisive_observations",
    "open_questions", "next_actions",
    "budget_state", "formalization_debt", "representative_failures", "archived_work_files",
    "previous_checkpoint", "compaction_plan_sha256",
    "checkpoint_sha256"
  ],
  "properties": {
    "schema_version": {"const": 3},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$", "maxLength": 64},
    "checkpoint_id": {"type": "string", "pattern": "^CHECKPOINT-[0-9]{6}$"},
    "created_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "brief": {
      "type": "object",
      "required": ["sha256", "approval_sha256"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "approval_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "repository_profile": {"$ref": "#/$defs/file_binding"},
    "host_change_scope": {"$ref": "#/$defs/host_change_scope"},
    "prepared_active_work_inventory_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "active_formal_artifacts": {"type": "array", "maxItems": 128, "items": {"$ref": "#/$defs/formal_file"}},
    "claims_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claims_snapshot": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "object"}},
    "inactive_claim_refs": {"type": "array", "maxItems": 256, "uniqueItems": true, "items": {"$ref": "#/$defs/inactive_claim_ref"}},
    "active_context_watermarks": {"$ref": "#/$defs/active_context_watermarks"},
    "frontier": {"type": "object"},
    "decisive_evidence": {"type": "array", "maxItems": 2048, "uniqueItems": true, "items": {"$ref": "#/$defs/evidence_ref"}},
    "contradictory_evidence": {"type": "array", "maxItems": 2048, "uniqueItems": true, "items": {"$ref": "#/$defs/evidence_ref"}},
    "decisive_observations": {"type": "array", "maxItems": 2048, "uniqueItems": true, "items": {"$ref": "#/$defs/observation_ref"}},
    "open_questions": {"type": "array", "maxItems": 64, "items": {"type": "string", "maxLength": 1024}},
    "next_actions": {"type": "array", "maxItems": 64, "items": {"type": "string", "maxLength": 1024}},
    "budget_state": {"type": "object"},
    "formalization_debt": {"type": "array", "maxItems": 64, "items": {"type": "object"}},
    "representative_failures": {"type": "array", "maxItems": 64, "items": {"$ref": "#/$defs/failure_ref"}},
    "archived_work_files": {"type": "array", "maxItems": 256, "items": {"$ref": "#/$defs/archived_file"}},
    "previous_checkpoint": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/checkpoint_ref"}
      ]
    },
    "compaction_plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "checkpoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "active_context_watermarks": {
      "type": "object",
      "required": ["run_count", "observation_record_count", "evidence_record_count"],
      "properties": {
        "run_count": {"type": "integer", "minimum": 0},
        "observation_record_count": {"type": "integer", "minimum": 0},
        "evidence_record_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "inactive_claim_ref": {
      "type": "object",
      "required": ["claim_id", "lifecycle", "state", "sha256", "record_path"],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^CLAIM-[0-9]{4,}$", "maxLength": 64},
        "lifecycle": {"enum": ["active", "retired", "superseded"]},
        "state": {"enum": ["proposed", "under_test", "partially_supported", "numerically_supported", "contradicted", "inconclusive"]},
        "superseded_by": {"type": "string", "pattern": "^CLAIM-[0-9]{4,}$", "maxLength": 64},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "record_path": {"type": "string", "minLength": 1, "maxLength": 1024}
      },
      "additionalProperties": false
    },
    "file_binding": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "host_change_scope": {
      "type": "object",
      "required": [
        "outcome", "git_available", "consequential_paths", "fingerprint_sha256"
      ],
      "properties": {
        "outcome": {"enum": ["PASS", "ADVISORY"]},
        "git_available": {"type": "boolean"},
        "consequential_paths": {
          "$ref": "#/$defs/bounded_host_paths"
        },
        "fingerprint_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "bounded_host_paths": {
      "type": "object",
      "required": [
        "items", "total_count", "selected_count", "truncated",
        "inventory_sha256", "selected_bytes"
      ],
      "properties": {
        "items": {
          "type": "array",
          "maxItems": 64,
          "items": {"$ref": "#/$defs/host_path"}
        },
        "total_count": {"type": "integer", "minimum": 0},
        "selected_count": {"type": "integer", "minimum": 0, "maximum": 64},
        "truncated": {"type": "boolean"},
        "inventory_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "selected_bytes": {"type": "integer", "minimum": 2, "maximum": 8192}
      },
      "additionalProperties": false
    },
    "host_path": {
      "type": "object",
      "required": ["path", "classification", "tracked", "states", "identity"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "classification": {"type": "string", "minLength": 1},
        "tracked": {"type": "boolean"},
        "states": {"type": "array", "items": {"type": "string"}},
        "identity": {"$ref": "#/$defs/path_identity"}
      },
      "additionalProperties": false
    },
    "path_identity": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["file", "missing", "symlink", "directory", "other"]},
        "mode": {"type": "integer", "minimum": 0},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "target": {"type": "string"}
      },
      "oneOf": [
        {"properties": {"kind": {"const": "file"}}, "required": ["mode", "size", "sha256"]},
        {"properties": {"kind": {"const": "missing"}}},
        {"properties": {"kind": {"const": "symlink"}}, "required": ["target"]},
        {"properties": {"kind": {"enum": ["directory", "other"]}}, "required": ["mode"]}
      ],
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "version", "sha256"],
      "properties": {
        "evidence_id": {"type": "string", "pattern": "^EVID-[0-9]{4,}$", "maxLength": 64},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "observation_ref": {
      "type": "object",
      "required": ["observation_id", "version", "sha256"],
      "properties": {
        "observation_id": {"type": "string", "pattern": "^OBS-[0-9]{4,}$", "maxLength": 64},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "formal_file": {
      "type": "object",
      "required": ["kind", "path", "size", "sha256", "active"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "active": {"const": true}
      },
      "additionalProperties": false
    },
    "checkpoint_ref": {
      "type": "object",
      "required": ["checkpoint_id", "sha256"],
      "properties": {
        "checkpoint_id": {"type": "string", "pattern": "^CHECKPOINT-[0-9]{6}$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "failure_ref": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["run", "failed_direction"]},
        "run_id": {"type": "string", "pattern": "^RUN-[0-9]{6}$"},
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {"required": ["run_id", "manifest_sha256"], "properties": {"kind": {"const": "run"}}},
        {"required": ["path", "size", "sha256"], "properties": {"kind": {"const": "failed_direction"}}}
      ],
      "additionalProperties": false
    },
    "archived_file": {
      "type": "object",
      "required": ["source_path", "archived_path", "size", "sha256"],
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "archived_path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
