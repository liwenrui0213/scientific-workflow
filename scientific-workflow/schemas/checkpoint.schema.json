{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/checkpoint.schema.json",
  "title": "Immutable research compaction Checkpoint",
  "type": "object",
  "required": [
    "schema_version", "study_id", "checkpoint_id", "created_at", "brief",
    "active_formal_artifacts", "claims_file_sha256", "claims_snapshot", "frontier",
    "decisive_evidence", "contradictory_evidence", "open_questions", "next_actions",
    "budget_state", "formalization_debt", "representative_failures", "archived_work_files",
    "previous_checkpoint", "compaction_plan_sha256",
    "checkpoint_sha256"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$"},
    "checkpoint_id": {"type": "string", "pattern": "^CHECKPOINT-[0-9]{6}$"},
    "created_at": {"type": "string", "minLength": 1},
    "brief": {
      "type": "object",
      "required": ["sha256", "approval_sha256"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "approval_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "active_formal_artifacts": {"type": "array", "items": {"$ref": "#/$defs/formal_file"}},
    "claims_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claims_snapshot": {"type": "array", "items": {"type": "object"}},
    "frontier": {"type": "object"},
    "decisive_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence_ref"}},
    "contradictory_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence_ref"}},
    "open_questions": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "budget_state": {"type": "object"},
    "formalization_debt": {"type": "array", "items": {"type": "object"}},
    "representative_failures": {"type": "array", "items": {"$ref": "#/$defs/failure_ref"}},
    "archived_work_files": {"type": "array", "items": {"$ref": "#/$defs/archived_file"}},
    "previous_checkpoint": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/checkpoint_ref"}
      ]
    },
    "compaction_plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "checkpoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "version", "sha256"],
      "properties": {
        "evidence_id": {"type": "string", "pattern": "^EVID-[0-9]{4,}$"},
        "version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "formal_file": {
      "type": "object",
      "required": ["kind", "path", "size", "sha256", "active"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "active": {"const": true}
      },
      "additionalProperties": false
    },
    "checkpoint_ref": {
      "type": "object",
      "required": ["checkpoint_id", "sha256"],
      "properties": {
        "checkpoint_id": {"type": "string", "pattern": "^CHECKPOINT-[0-9]{6}$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "failure_ref": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["run", "failed_direction"]},
        "run_id": {"type": "string", "pattern": "^RUN-[0-9]{6}$"},
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {"required": ["run_id", "manifest_sha256"], "properties": {"kind": {"const": "run"}}},
        {"required": ["path", "size", "sha256"], "properties": {"kind": {"const": "failed_direction"}}}
      ],
      "additionalProperties": false
    },
    "archived_file": {
      "type": "object",
      "required": ["source_path", "archived_path", "size", "sha256"],
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "archived_path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
