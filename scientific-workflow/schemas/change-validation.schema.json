{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Study source and test validation proof",
  "type": "object",
  "required": [
    "schema_version",
    "study_id",
    "created_at",
    "repository_profile",
    "changeset",
    "git",
    "changed_paths",
    "validated_tree_sha256",
    "commands",
    "repository_state_unchanged",
    "passed",
    "record_sha256"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$"},
    "created_at": {"type": "string", "minLength": 1},
    "repository_profile": {"$ref": "#/$defs/fileRef"},
    "changeset": {"$ref": "#/$defs/fileRef"},
    "git": {
      "type": "object",
      "required": ["commit", "branch"],
      "properties": {
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "branch": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "changed_paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "validated_tree_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "argv",
          "started_at",
          "ended_at",
          "exit_code",
          "stdout_sha256",
          "stderr_sha256",
          "stdout_tail",
          "stderr_tail"
        ],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "started_at": {"type": "string", "minLength": 1},
          "ended_at": {"type": "string", "minLength": 1},
          "exit_code": {"type": "integer"},
          "stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "stdout_tail": {"type": "string"},
          "stderr_tail": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "repository_state_unchanged": {"type": "boolean"},
    "passed": {"type": "boolean"},
    "record_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "fileRef": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
