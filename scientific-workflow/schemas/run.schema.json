{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scientific-workflow/run.schema.json",
  "title": "Immutable scientific Run manifest",
  "type": "object",
  "required": [
    "schema_version",
    "study_id",
    "run_id",
    "purpose",
    "status",
    "epistemic_role",
    "execution",
    "git",
    "code_state",
    "change_scope",
    "brief",
    "formal_artifacts",
    "formalization",
    "cohort",
    "environment",
    "budget",
    "inputs",
    "outputs",
    "logs",
    "failure",
    "integrity"
  ],
  "properties": {
    "schema_version": {"const": 4},
    "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$"},
    "run_id": {"type": "string", "pattern": "^RUN-[0-9]{6}$"},
    "purpose": {"type": "string", "minLength": 1},
    "status": {"enum": ["succeeded", "failed", "interrupted", "incomplete", "running"]},
    "epistemic_role": {
      "oneOf": [
        {
          "type": "object",
          "required": ["mode", "confirmation_id", "confirmation_sha256", "slot_id"],
          "properties": {
            "mode": {"const": "exploratory"},
            "confirmation_id": {"type": "null"},
            "confirmation_sha256": {"type": "null"},
            "slot_id": {"type": "null"}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["mode", "confirmation_id", "confirmation_sha256", "slot_id"],
          "properties": {
            "mode": {"const": "confirmatory"},
            "confirmation_id": {"type": "string", "pattern": "^CONF-[0-9]{4,}$", "maxLength": 64},
            "confirmation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "slot_id": {"type": "string", "pattern": "^SLOT-[0-9]{3,}$", "maxLength": 64}
          },
          "additionalProperties": false
        }
      ]
    },
    "execution": {
      "type": "object",
      "required": [
        "argv", "cwd", "cwd_relative", "started_at", "ended_at",
        "duration_seconds", "exit_code", "seed"
      ],
      "properties": {
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "cwd": {"type": "string", "minLength": 1},
        "cwd_relative": {"type": "string", "minLength": 1},
        "started_at": {"type": "string", "minLength": 1},
        "ended_at": {"type": ["string", "null"]},
        "duration_seconds": {"type": ["number", "null"], "minimum": 0},
        "exit_code": {"type": ["integer", "null"]},
        "seed": {"type": ["integer", "string", "null"]}
      },
      "additionalProperties": false
    },
    "execution_boundary": {
      "type": "object",
      "required": [
        "mode", "backend", "policy_sha256", "environment_allowlist",
        "network_access", "repository_write_access", "declared_inputs_only",
        "declared_outputs_only", "read_only_paths", "writable_paths"
      ],
      "properties": {
        "mode": {"const": "sealed"},
        "backend": {"enum": ["linux-bubblewrap", "macos-seatbelt"]},
        "backend_version": {"type": "string", "minLength": 1, "maxLength": 256},
        "policy_format": {
          "enum": ["bubblewrap-mount-policy-v1", "seatbelt-profile-v1"]
        },
        "policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "environment_allowlist": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "environment_variables": {
          "type": "object",
          "propertyNames": {"type": "string", "minLength": 1},
          "additionalProperties": {"type": "string"}
        },
        "environment_sha256": {
          "type": "string", "pattern": "^[0-9a-f]{64}$"
        },
        "network_access": {"const": false},
        "repository_write_access": {"const": false},
        "declared_inputs_only": {"const": true},
        "declared_outputs_only": {"const": true},
        "read_only_paths": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "writable_paths": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "output_staging": {"enum": ["direct", "private-copy-out"]},
        "device_paths": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"backend": {"const": "linux-bubblewrap"}},
            "required": ["backend"]
          },
          "then": {
            "required": [
              "backend_version", "policy_format", "output_staging", "device_paths",
              "environment_variables", "environment_sha256"
            ],
            "properties": {
              "policy_format": {"const": "bubblewrap-mount-policy-v1"},
              "output_staging": {"const": "private-copy-out"}
            }
          }
        },
        {
          "if": {
            "properties": {
              "backend": {"const": "macos-seatbelt"},
              "policy_format": {"type": "string"}
            },
            "required": ["backend", "policy_format"]
          },
          "then": {
            "properties": {
              "policy_format": {"const": "seatbelt-profile-v1"}
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "git": {
      "type": "object",
      "required": ["available", "commit", "dirty", "status", "status_sha256"],
      "properties": {
        "available": {"type": "boolean"},
        "commit": {"type": ["string", "null"]},
        "dirty": {"type": ["boolean", "null"]},
        "status": {"type": "array", "items": {"type": "string"}},
        "status_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "code_state": {
      "type": "object",
      "required": ["before", "after", "changed_during_run"],
      "properties": {
        "before": {"$ref": "#/$defs/tracked_code_state"},
        "after": {"$ref": "#/$defs/tracked_code_state"},
        "changed_during_run": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "change_scope": {
      "type": "object",
      "required": [
        "repository_profile",
        "changeset",
        "validation",
        "before",
        "after",
        "evidence_eligible"
      ],
      "properties": {
        "repository_profile": {"$ref": "#/$defs/file_hash"},
        "changeset": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/file_hash"}
          ]
        },
        "validation": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/file_hash"}
          ]
        },
        "before": {"$ref": "#/$defs/change_check"},
        "after": {"$ref": "#/$defs/change_check"},
        "evidence_eligible": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "brief": {
      "type": "object",
      "required": [
        "path",
        "sha256",
        "approval_sha256",
        "snapshot",
        "approval_snapshot"
      ],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "approval_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "snapshot": {"$ref": "#/$defs/file_hash"},
        "approval_snapshot": {"$ref": "#/$defs/file_hash"}
      },
      "additionalProperties": false
    },
    "formal_artifacts": {"type": "array", "items": {"$ref": "#/$defs/file_hash"}},
    "formalization": {
      "type": "object",
      "required": [
        "changed_paths",
        "declared_changed_paths",
        "actual_changed_paths",
        "scientific_critical",
        "shared_across_runs",
        "artifacts_unchanged_during_run",
        "outcome",
        "requirements"
      ],
      "properties": {
        "changed_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "declared_changed_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "actual_changed_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "scientific_critical": {"type": "boolean"},
        "shared_across_runs": {"type": "boolean"},
        "artifacts_unchanged_during_run": {"type": "boolean"},
        "outcome": {"enum": ["PASS", "ADVISORY", "BLOCKED"]},
        "requirements": {"type": "array", "items": {"type": "object"}}
      },
      "additionalProperties": false
    },
    "cohort": {
      "type": "object",
      "required": ["cohort_id", "fields", "fingerprint_sha256"],
      "properties": {
        "cohort_id": {"type": ["string", "null"], "pattern": "^COHORT-[0-9]{3,}$"},
        "fields": {"type": "object"},
        "fingerprint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": [
        "python_executable", "python_version", "python_implementation",
        "platform", "system", "release", "machine", "processor",
        "hardware_class", "precision", "environment_variables"
      ],
      "properties": {
        "python_executable": {"type": "string", "minLength": 1},
        "python_version": {"type": "string", "minLength": 1},
        "python_implementation": {"type": "string", "minLength": 1},
        "platform": {"type": "string", "minLength": 1},
        "system": {"type": "string", "minLength": 1},
        "release": {"type": "string"},
        "machine": {"type": "string"},
        "processor": {"type": "string"},
        "hardware_class": {"type": "string", "minLength": 1},
        "precision": {"type": "string", "minLength": 1},
        "environment_variables": {"type": "object"}
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "required": [
        "estimated_gpu_hours",
        "estimated_cpu_hours",
        "estimated_storage_gb",
        "actual_output_storage_gb",
        "hard_limits",
        "committed_before",
        "requested",
        "committed_after",
        "violations"
      ],
      "properties": {
        "estimated_gpu_hours": {"type": "number", "minimum": 0},
        "estimated_cpu_hours": {"type": "number", "minimum": 0},
        "estimated_storage_gb": {"type": "number", "minimum": 0},
        "actual_output_storage_gb": {"type": ["number", "null"], "minimum": 0},
        "hard_limits": {"$ref": "#/$defs/hard_budget"},
        "committed_before": {"$ref": "#/$defs/resource_amounts"},
        "requested": {"$ref": "#/$defs/resource_amounts"},
        "committed_after": {"$ref": "#/$defs/resource_amounts"},
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["resource", "committed", "requested", "projected", "limit"],
            "properties": {
              "resource": {"enum": ["gpu_hours", "cpu_hours", "storage_gb"]},
              "committed": {"type": "number", "minimum": 0},
              "requested": {"type": "number", "minimum": 0},
              "projected": {"type": "number", "minimum": 0},
              "limit": {"type": ["number", "null"], "minimum": 0}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "inputs": {"type": "array", "items": {"$ref": "#/$defs/input_record"}},
    "outputs": {"type": "array", "items": {"$ref": "#/$defs/output_record"}},
    "logs": {
      "type": "object",
      "required": ["stdout", "stderr"],
      "properties": {
        "stdout": {"$ref": "#/$defs/file_hash"},
        "stderr": {"$ref": "#/$defs/file_hash"}
      },
      "additionalProperties": false
    },
    "failure": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["phase", "type", "message"],
          "properties": {
            "phase": {"type": "string", "minLength": 1},
            "type": {"type": "string", "minLength": 1},
            "message": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        }
      ]
    },
    "integrity": {
      "type": "object",
      "required": ["sealed_at", "manifest_sha256"],
      "properties": {
        "sealed_at": {"type": ["string", "null"]},
        "manifest_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "resource_amounts": {
      "type": "object",
      "required": ["gpu_hours", "cpu_hours", "storage_gb"],
      "properties": {
        "gpu_hours": {"type": "number", "minimum": 0},
        "cpu_hours": {"type": "number", "minimum": 0},
        "storage_gb": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "hard_budget": {
      "type": "object",
      "required": ["gpu_hours", "cpu_hours", "storage_gb"],
      "properties": {
        "gpu_hours": {"type": ["number", "null"], "minimum": 0},
        "cpu_hours": {"type": ["number", "null"], "minimum": 0},
        "storage_gb": {"type": ["number", "null"], "minimum": 0}
      },
      "additionalProperties": false
    },
    "change_check": {
      "type": "object",
      "required": [
        "schema_version",
        "study_id",
        "outcome",
        "git",
        "changeset",
        "validation",
        "changed_paths",
        "violations",
        "advisories"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "study_id": {"type": "string", "pattern": "^SC-[0-9]{4,}$"},
        "outcome": {"enum": ["PASS", "ADVISORY", "BLOCKED"]},
        "git": {"type": "object"},
        "changeset": {"type": ["object", "null"]},
        "validation": {"type": ["object", "null"]},
        "changed_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "classification", "tracked", "states"],
            "properties": {
              "path": {"type": "string", "minLength": 1},
              "classification": {
                "enum": [
                  "study_state",
                  "other_study",
                  "output_object",
                  "generated",
                  "vendor",
                  "test",
                  "experiment",
                  "workflow",
                  "source",
                  "other"
                ]
              },
              "tracked": {"type": "boolean"},
              "states": {
                "type": "array",
                "items": {"enum": ["committed", "staged", "unstaged", "untracked"]}
              }
            },
            "additionalProperties": false
          }
        },
        "violations": {"type": "array", "items": {"type": "object"}},
        "advisories": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "tracked_code_state": {
      "type": "object",
      "required": ["available", "commit", "diff_sha256"],
      "properties": {
        "available": {"type": "boolean"},
        "commit": {"type": ["string", "null"]},
        "diff_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "file_hash": {
      "type": "object",
      "required": ["path", "size", "sha256"],
      "properties": {
        "kind": {"type": "string"},
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "input_record": {
      "type": "object",
      "required": ["path", "size", "sha256_before", "sha256_after", "changed_during_run"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256_before": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "sha256_after": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "changed_during_run": {"type": ["boolean", "null"]}
      },
      "additionalProperties": false
    },
    "output_record": {
      "type": "object",
      "required": ["path", "present", "size", "sha256", "classification", "pinned"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "present": {"type": "boolean"},
        "size": {"type": ["integer", "null"], "minimum": 0},
        "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "classification": {"enum": ["ordinary", "baseline", "unique_anomaly"]},
        "pinned": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
